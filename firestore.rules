rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 예약된 좌석 목록 (실제 예매 + 관리자 차단)
    match /seats/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // 예매 내역 — 누구나 읽기/쓰기 가능 (로그인은 앱 레벨에서 처리)
    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if true;
    }

    // 사용자 프로필 (이메일-전화번호 매핑)
    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    // 관리자 인증 — 읽기만 허용 (비밀번호는 SHA-256 해시로 저장)
    match /admin/credentials {
      allow read: if true;
      allow write: if false;
    }

    // 좌석별 액션 히스토리
    match /seatHistory/{seatId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
